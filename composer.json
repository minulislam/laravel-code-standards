{
    "name": "multicoin/laravel-code-standards",
    "description": "Strict OOP code standards for Laravel with automated linting and review tools",
    "type": "library",
    "keywords": [
        "laravel",
        "code-standards",
        "oop",
        "phpstan",
        "pint",
        "code-review"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Multi Coin",
            "email": "multicoin@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Multicoin\\LaravelCodeStandards\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Multicoin\\LaravelCodeStandards\\CodeStandardsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
